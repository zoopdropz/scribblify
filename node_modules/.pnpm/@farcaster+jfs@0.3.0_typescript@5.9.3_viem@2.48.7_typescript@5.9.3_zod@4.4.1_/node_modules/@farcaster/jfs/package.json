{
  "name": "@farcaster/jfs",
  "version": "0.3.0",
  "description": "JSON Farcaster Signature implementation",
  "repository": {
    "type": "git",
    "url": "https://github.com/farcasterxyz/auth-monorepo.git",
    "directory": "packages/jfs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">= 5.8.3",
    "viem": "2.x"
  },
  "dependencies": {
    "@noble/curves": "2.x"
  },
  "devDependencies": {
    "viem": "^2.37.13",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}