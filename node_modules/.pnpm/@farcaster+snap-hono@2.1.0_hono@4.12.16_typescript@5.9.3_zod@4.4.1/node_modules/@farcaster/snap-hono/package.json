{
  "name": "@farcaster/snap-hono",
  "version": "2.1.0",
  "description": "Hono integration for Farcaster Snap servers",
  "repository": {
    "type": "git",
    "url": "https://github.com/farcasterxyz/snap.git",
    "directory": "pkgs/hono"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "satori": "^0.10.0",
    "@farcaster/snap": "2.2.0"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "@farcaster/jfs": "^0.2.2",
    "@types/node": "^25.5.0",
    "hono": "^4.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}