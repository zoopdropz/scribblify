{
  "name": "@farcaster/snap",
  "version": "2.2.0",
  "description": "Farcaster Snaps 🫰",
  "repository": {
    "type": "git",
    "url": "https://github.com/farcasterxyz/snap.git",
    "directory": "pkgs/snap"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
