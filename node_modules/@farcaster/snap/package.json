  "files": [
    "dist",
    "src",
    "llms.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@farcaster/jfs": "^0.3.0",
    "@json-render/core": "^0.15.0",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "zod": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "@json-render/react": "*",
    "@neynar/ui": "*",
    "lucide-react": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@json-render/react": {
      "optional": true
    },
    "@neynar/ui": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^4.0.0"
  },
  "scripts": {
    "build": "tsc && (tsc -p tsconfig.react-native.json || true) && tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}