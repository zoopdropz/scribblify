      "types": "./dist/ui/progress.d.ts",
      "import": "./dist/ui/progress.js",
      "default": "./dist/ui/progress.js"
    },
    "./ui/separator": {
      "types": "./dist/ui/separator.d.ts",
      "import": "./dist/ui/separator.js",
      "default": "./dist/ui/separator.js"
